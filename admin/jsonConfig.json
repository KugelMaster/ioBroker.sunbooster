{
    "i18n": true,
    "type": "tabs",
    "items": {
        "_device_and_credentials": {
            "type": "panel",
            "label": "Device and Credentials",
            "items": {
                "email": {
                    "type": "text",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Account Email",
                    "help": "The email of your Sunbooster Account"
                },
                "password": {
                    "type": "password",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Account Password",
                    "help": "The password of your Sunbooster Account"
                },
                "deviceKey": {
                    "newLine": true,
                    "type": "text",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Device Key"
                },
                "productKey": {
                    "type": "text",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Product Key"
                }
            }
        },
        "_options": {
            "type": "panel",
            "label": "Options",
            "items": {
                "pollInterval": {
                    "type": "number",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Poll Interval",
                    "help": "The poll rate in seconds for requesting device data"
                },
                "wsMaxRetries": {
                    "type": "number",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Max Retries",
                    "help": "How often the WebSocket tries to reconnect if an error occured"
                },
                "wsRetryInterval": {
                    "type": "number",
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "label": "Retry Interval",
                    "help": "How long the WebSocket waits between reconnects"
                }
            }
        }
    }
}